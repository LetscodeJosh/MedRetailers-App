<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dna_background"
    tools:context=".Activity_CompleteView_Details">

    <ImageView
        android:id="@+id/imgDnaBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="2.0"
        android:scaleType="centerCrop"
        android:src="@drawable/dna_background" />

    <ImageView
        android:id="@+id/imgHeaderLogo"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/medretailer_official_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgTopDecor"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:src="@drawable/ic_hamburger"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/dividerTop"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:background="#40000000"
        app:layout_constraintTop_toBottomOf="@id/imgHeaderLogo" />

    <TextView
        android:id="@+id/tvHeaderCustomerName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="start|center_vertical"
        android:text="Customer: Loading..."
        android:textColor="#835C9F"
        android:textSize="20sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dividerTop" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnApproveActions"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_action_pill_interactive"
        android:textColor="#835C9F"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:paddingHorizontal="16dp"
        android:drawableEnd="@drawable/ic_selector_arrows"
        android:drawablePadding="8dp"
        android:text="Actions"
        android:elevation="2dp"
        android:stateListAnimator="@null"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dividerTop" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        style="@style/CustomTabStyle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderCustomerName"
        app:layout_constraintWidth_max="600dp">
    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="#80FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/layoutEditActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintVertical_bias="0.0">

        <include
            android:id="@+id/include_details"
            layout="@layout/layout_tab_details"
            android:visibility="visible" />

        <include
            android:id="@+id/include_address"
            layout="@layout/layout_tab_addresscontact"
            android:visibility="gone" />

        <include
            android:id="@+id/include_terms"
            layout="@layout/layout_tab_terms"
            android:visibility="gone" />

        <include
            android:id="@+id/include_moreinfo"
            layout="@layout/layout_tab_moreinfo"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layoutEditActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/dividerBottom"
        app:layout_constraintTop_toBottomOf="@id/contentContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnEditOrder"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:src="@drawable/editbutton"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <View
        android:id="@+id/dividerBottom"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"
        android:background="#40000000"
        app:layout_constraintBottom_toTopOf="@+id/iconBottleLeft"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iconBottleLeft"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/medicine_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/iconBottleRight"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/medicine_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>