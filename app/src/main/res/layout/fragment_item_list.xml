<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/tableHeader"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="#30835C9F"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <CheckBox
            android:id="@+id/cbSelectAll"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:buttonTint="#835C9F" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#835C9F" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center"
            android:text="Item Name"
            android:textColor="#835C9F"
            android:textSize="10sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#835C9F" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:gravity="center"
            android:text="Date"
            android:textColor="#835C9F"
            android:textSize="10sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#835C9F" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Qty"
            android:textColor="#835C9F"
            android:textSize="10sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#835C9F" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Rate"
            android:textColor="#835C9F"
            android:textSize="10sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#835C9F" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:gravity="center"
            android:text="Amount"
            android:textColor="#835C9F"
            android:textSize="10sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/buttonsContainer"
        app:layout_constraintTop_toBottomOf="@id/tableHeader"
        tools:listitem="@layout/itemlist_row" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/btnimgaddrow"
            android:layout_width="75dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:src="@drawable/addrow"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/btnimgdeleterow"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/deleterow"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnimgaddrow" />

        <ImageView
            android:id="@+id/btnimgsubmitforapproval"
            android:layout_width="130dp"
            android:layout_height="40dp"
            android:layout_marginEnd="25dp"
            android:src="@drawable/submitforapproval"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTotalAmount"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_total_field"
            android:gravity="center"
            android:text="₱ 0.00"
            android:textColor="#835C9F"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/btnimgaddrow"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvTotalQty"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_total_field"
            android:gravity="center"
            android:text="0"
            android:textColor="#835C9F"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/tvTotalAmount"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>