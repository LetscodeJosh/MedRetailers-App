<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity_TermsConditions">

    <ImageView
        android:id="@+id/imgDnaBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="2.0"
        android:scaleType="centerCrop"
        android:src="@drawable/dna_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgHeaderLogo"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:contentDescription="MedRetailers Logo"
        android:src="@drawable/medretailer_official_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgTopDecor"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:src="@drawable/ic_hamburger"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/dividerBottom2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="64dp"
        android:background="#40000000"
        app:layout_constraintTop_toTopOf="@+id/imgDnaBackground"
        tools:layout_editor_absoluteX="24dp" />

    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="Order Details"
        android:textColor="#835C9F"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        style="@style/CustomTabStyle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPageTitle"
        app:layout_constraintWidth_max="600dp">
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Details" />
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Items" />
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Address" />
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terms" />
    </com.google.android.material.tabs.TabLayout>


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        android:layout_gravity="center_horizontal"
        app:layout_constraintBottom_toTopOf="@+id/btnSubmitforapproval"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tabLayout"
        app:layout_constraintWidth_max="600dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Terms Template"
                android:textColor="#835C9F"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <AutoCompleteTextView
                android:id="@+id/etPaymentTerms"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/blank_placeholder"
                android:hint="Select Payment Terms..."
                android:textColorHint="#835C9F"
                android:paddingStart="16dp"
                android:gravity="center_vertical"
                android:textColor="#835C9F"
                android:completionThreshold="1"
                android:overlapAnchor="false"
                android:maxLines="1"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/etInstructions"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/blank_placeholder"
                android:hint="Additional Instructions..."
                android:textColorHint="#835C9F"
                android:padding="16dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:textColor="#835C9F"
                android:textSize="@dimen/text_title" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Schedule"
                android:textColor="#835C9F"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="5dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="6dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="#FFFFFF">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <TableLayout
                        android:id="@+id/tablePaymentSchedule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:stretchColumns="3">

                        <TableRow
                            android:background="#835C9F"
                            android:paddingVertical="12dp"
                            android:paddingHorizontal="8dp">

                            <CheckBox
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="#FFFFFF"
                                android:layout_gravity="center_vertical"/>

                            <TextView
                                android:text="No."
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:padding="8dp"
                                android:layout_gravity="center_vertical"/>

                            <TextView
                                android:text="Payment Term"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:padding="8dp"
                                android:minWidth="120dp"
                                android:layout_gravity="center_vertical"/>

                            <TextView
                                android:text="Description"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:padding="8dp"
                                android:minWidth="150dp"
                                android:layout_gravity="center_vertical"/>

                            <TextView
                                android:text="Due Date *"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:padding="8dp"
                                android:minWidth="100dp"
                                android:layout_gravity="center_vertical"/>

                            <TextView
                                android:text="Portion (%)"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:padding="8dp"
                                android:minWidth="80dp"
                                android:layout_gravity="center_vertical"/>
                            <TextView
                                android:text="Amount (PHP) *"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:padding="8dp"
                                android:minWidth="100dp"
                                android:layout_gravity="center_vertical"/>

                            <View
                                android:layout_width="24dp"
                                android:layout_height="24dp" />
                        </TableRow>
                    </TableLayout>
                </HorizontalScrollView>
            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSubmitforapproval"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:layout_marginBottom="16dp"
        android:minWidth="160dp"
        android:background="@drawable/bg_action_pill"
        android:text="Submit for Approval"
        android:textAllCaps="false"
        android:textColor="#835C9F"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tabLayout"
        app:layout_constraintVertical_bias="0.861" />

    <View
        android:id="@+id/dividerBottom3"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="70dp"
        android:layout_marginHorizontal="24dp"
        android:background="#40000000"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/iconBottleLeft"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/medicine_icon"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/iconBottleRight"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/medicine_icon"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>