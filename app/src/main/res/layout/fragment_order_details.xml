<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/btnSubmitOrder"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp"
            android:paddingTop="16dp">

            <TextView
                android:text="Approval Status"
                android:textColor="#835C9F"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etApprovalStatus"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/blank_placeholder"
                android:paddingHorizontal="12dp"
                android:enabled="false"
                android:hint=""
                android:textColor="#333"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:text="Order Fulfillment Status"
                android:textColor="#835C9F"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etFulfillmentStatus"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/blank_placeholder"
                android:paddingHorizontal="12dp"
                android:enabled="false"
                android:hint=""
                android:textColor="#333"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:text="Customer *"
                        android:textColor="#835C9F"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <AutoCompleteTextView
                        android:id="@+id/etCustomer"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/blank_placeholder"
                        android:paddingHorizontal="12dp"
                        android:hint="Search Customer..."
                        android:textSize="14sp"
                        android:textColor="#835C9F"
                        android:completionThreshold="1"
                        android:maxLines="1"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:text="Date *"
                        android:textColor="#835C9F"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:id="@+id/etDate"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/blank_placeholder"
                        android:paddingHorizontal="12dp"
                        android:text="02/12/2026"
                        android:textSize="14sp"
                        android:textColor="#835C9F"
                        android:focusable="false"
                        android:clickable="true"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:text="Delivery Date"
                        android:textColor="#835C9F"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:id="@+id/etDeliveryDate"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/blank_placeholder"
                        android:paddingHorizontal="12dp"
                        android:text="02/27/2026"
                        android:textSize="14sp"
                        android:textColor="#835C9F"
                        android:focusable="false"
                        android:clickable="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:text="Company *"
                        android:textColor="#835C9F"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <AutoCompleteTextView
                        android:id="@+id/etCompany"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/blank_placeholder"
                        android:paddingHorizontal="12dp"
                        android:hint="Select Company..."
                        android:textSize="14sp"
                        android:textColor="#835C9F"
                        android:completionThreshold="1"
                        android:maxLines="1"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp"/>

            <TextView
                android:text="Customer's Purchase Order"
                android:textColor="#835C9F"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etPO"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/blank_placeholder"
                android:paddingHorizontal="12dp"
                android:hint=""
                android:textColor="#835C9F"/>

            <View android:layout_width="match_parent" android:layout_height="12dp"/>

            <TextView
                android:text="Order Type *"
                android:textColor="#835C9F"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etOrderType"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/blank_placeholder"
                android:paddingHorizontal="12dp"
                android:text="Sales"
                android:enabled="false"
                android:textColor="#835C9F"/>

            <Spinner
                android:id="@+id/spTerritory"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <ImageView
        android:id="@+id/btnSubmitOrder"
        android:layout_width="150dp"
        android:layout_height="40dp"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/submitforapproval"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>