<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base background - Slightly off-white for depth -->
    <path
        android:fillColor="#F4F6F8"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Soft Radial Gradient for the Orb feel -->
    <path
        android:pathData="M54,54m-54,0a54,54 0,1 1,108 0a54,54 0,1 1,-108 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="45"
                android:gradientRadius="65"
                android:type="radial">
                <item android:offset="0" android:color="#FFFFFF" />
                <item android:offset="0.7" android:color="#ECEFF2" />
                <item android:offset="1" android:color="#DDE2E6" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- The Glossy Highlight (Top Reflection) -->
    <path
        android:pathData="M54,35m-45,0a45,25 0,1 1,90 0a45,25 0,1 1,-90 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="15"
                android:gradientRadius="40"
                android:type="radial">
                <item android:offset="0" android:color="#60FFFFFF" />
                <item android:offset="1" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle Inner Ring/Border to mimic the glass edge -->
    <path
        android:pathData="M54,54m-52,0a52,52 0,1 1,104 0a52,52 0,1 1,-104 0"
        android:strokeWidth="1.5"
        android:strokeColor="#C0C8D0"
        android:fillColor="#00000000" />

</vector>
