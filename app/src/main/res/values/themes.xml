<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MedRetailerPoC" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="CustomSearchViewStyle" parent="Widget.AppCompat.SearchView">
        <item name="android:editTextColor">#835C9F</item>
        <item name="android:textColorHint">#80835C9F</item>
        <item name="android:textSize">13sp</item>
        <item name="searchHintIcon">@null</item>
        <item name="closeIcon">@android:drawable/ic_menu_close_clear_cancel</item>
        <item name="queryBackground">@android:color/transparent</item>
        <item name="submitBackground">@android:color/transparent</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingStart">0dp</item>
    </style>

    <style name="Theme.MedRetailerPoC" parent="Base.Theme.MedRetailerPoC" >
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Clean Tab Style -->
    <style name="CustomTabStyle" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">#835C9F</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabSelectedTextColor">#835C9F</item>
        <item name="tabTextColor">#888888</item>
        <item name="tabTextAppearance">@style/CustomTabTextAppearance</item>
        <item name="tabRippleColor">#20835C9F</item>
        <item name="tabMaxWidth">0dp</item>
        <item name="tabGravity">fill</item>
        <item name="tabMode">fixed</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="CustomTabTextAppearance" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>